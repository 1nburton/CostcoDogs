{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "autoIncrement": true,
      "ios": {
        "credentialsSource": "remote",
        "image": "latest"
      }
    },
    "local": {
      "ios": {
        "credentialsSource": "local"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "$(EXPO_ASC_APP_ID)"
      }
    }
  }
}
